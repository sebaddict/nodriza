<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NODRIZA — Módulos de Servicio</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --verde: #2E4E42; --verde-light: #3d6657; --verde-dark: #1e352c;
  --crema: #F7F1E6; --arena: #D2C4A7; --arena-dark: #b8a98a;
  --blanco: #FDFAF4; --font-title: 'Playfair Display',Georgia,serif;
  --font-body: 'Montserrat',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);background:var(--crema);color:var(--verde-dark);line-height:1.7}
.nav{position:fixed;top:0;left:0;right:0;z-index:100;background:var(--verde);padding:0 40px;display:flex;align-items:center;justify-content:space-between;height:60px}
.nav-brand{font-family:var(--font-title);color:var(--crema);font-size:20px;font-weight:700;letter-spacing:0.06em;text-decoration:none}
.nav-back{color:var(--arena);font-size:13px;font-weight:600;text-decoration:none;display:flex;align-items:center;gap:8px;letter-spacing:0.04em}
.nav-back:hover{color:var(--crema)}
.hero{min-height:45vh;background:var(--verde-dark);display:flex;align-items:center;justify-content:center;padding:100px 40px 60px;text-align:center}
.hero-tag{font-size:11px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--arena);margin-bottom:20px}
.hero-title{font-family:var(--font-title);font-size:clamp(40px,6vw,72px);color:var(--crema);line-height:1.1;margin-bottom:16px}
.hero-title em{font-style:italic;color:var(--arena)}
.hero-sub{font-size:16px;color:rgba(247,241,230,0.7);max-width:560px;margin:0 auto}
.container{max-width:1100px;margin:0 auto;padding:0 40px}
.modules{padding:80px 0}
.module{background:var(--blanco);border-radius:24px;overflow:hidden;margin-bottom:48px;box-shadow:0 8px 40px rgba(46,78,66,0.08)}
.module-header{background:var(--verde);padding:40px 48px;display:flex;align-items:center;gap:24px}
.module-num{font-family:var(--font-title);font-size:52px;color:rgba(247,241,230,0.2);font-weight:900;line-height:1}
.module-title-wrap{flex:1}
.module-label{font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--arena);margin-bottom:6px}
.module-title{font-family:var(--font-title);font-size:28px;color:var(--crema);line-height:1.2}
.module-icon{width:64px;height:64px;background:rgba(247,241,230,0.12);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px}
.module-body{padding:48px;display:grid;grid-template-columns:1fr 1fr;gap:40px}
@media(max-width:700px){.module-body{grid-template-columns:1fr}}
.module-desc{font-size:15px;color:#555;line-height:1.75;margin-bottom:24px}
.module-features{list-style:none}
.module-features li{padding:10px 0;border-bottom:1px solid rgba(210,196,167,0.3);font-size:14px;display:flex;align-items:flex-start;gap:10px}
.module-features li::before{content:"→";color:var(--verde);font-weight:700;flex-shrink:0}
.module-aside{background:var(--crema);border-radius:16px;padding:28px}
.aside-title{font-family:var(--font-title);font-size:17px;color:var(--verde-dark);margin-bottom:16px}
.aside-list{list-style:none}
.aside-list li{font-size:13px;padding:8px 0;border-bottom:1px solid rgba(210,196,167,0.4);color:#555}
.price-tag{background:var(--verde);color:var(--crema);border-radius:12px;padding:20px;margin-top:16px;text-align:center}
.price-tag .price{font-family:var(--font-title);font-size:36px;font-weight:700}
.price-tag .period{font-size:12px;opacity:0.7;margin-top:4px}
.btn-module{display:inline-flex;align-items:center;gap:8px;background:var(--verde);color:var(--crema);padding:14px 28px;border-radius:40px;font-size:13px;font-weight:700;text-decoration:none;margin-top:24px;letter-spacing:0.04em;transition:all 0.2s}
.btn-module:hover{background:var(--verde-dark);transform:translateY(-2px)}
.back-bar{background:var(--verde-dark);padding:24px 40px;text-align:center}
.back-bar a{color:var(--arena);text-decoration:none;font-size:13px;letter-spacing:0.06em}
</style>
</head>
<body>
<nav class="nav">
  <a href="index.html" class="nav-brand">NODRIZA</a>
  <a href="index.html" class="nav-back">← Volver al inicio</a>
</nav>

<div class="hero">
